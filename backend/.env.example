# DeepDive AI — Environment Variables
# Copy this file to .env and fill in your values

# HuggingFace API Token (required)
# Get yours free at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Qdrant Cloud — free hosted vector DB (required for persistence)
# Sign up free at: https://cloud.qdrant.io → create cluster → copy URL + API key
# Leave empty to use in-memory Qdrant locally (data lost on restart — dev only)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
